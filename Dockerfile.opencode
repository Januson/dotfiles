# syntax=docker/dockerfile:1
FROM alpine:latest AS installer

RUN apk add --no-cache curl bash tar
RUN curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path

FROM alpine:latest

RUN apk add --no-cache \
  ca-certificates \
  git \
  ripgrep \
  fd \
  libstdc++ \
  && adduser -D -h /home/dev dev \
  && mkdir -p /home/dev/.config/opencode \
  && chown dev:dev /home/dev/.config/opencode

COPY --from=installer /root/.opencode/bin/opencode /usr/local/bin/opencode
COPY ./dot_config/opencode /home/dev/.config/opencode

WORKDIR /work

ENTRYPOINT ["opencode"]
CMD []
