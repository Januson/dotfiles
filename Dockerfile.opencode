# syntax=docker/dockerfile:1
FROM alpine:latest AS installer

RUN apk add --no-cache curl bash tar libstdc++
RUN curl -fsSL https://opencode.ai/install | bash -s -- --no-modify-path

FROM alpine:latest

ENV LANG=C.UTF-8

RUN apk add --no-cache \
  ca-certificates \
  git \
  ripgrep \
  fd \
  libstdc++ \
  && adduser -D -h /home/dev dev

COPY --from=installer /root/.opencode/bin/opencode /usr/local/bin/opencode

WORKDIR /work
USER dev

ENTRYPOINT ["opencode"]
CMD []
